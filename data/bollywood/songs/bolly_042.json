  "key_phrase": "रंग दे तू मोहे गेरुआ",
  "expressions": [
    {
      "text": "रंग दे तू मोहे गेरुआ",
      "normalized": "रंग दे तू मोहे गेरुआ",
      "meaning_ja": "私をサフラン色に染めてください",
      "type": "key_phrase",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "हम मिले जहाँ पर, लम्हा थम गया",
      "normalized": "हम मिले जहां पर लम्हा थम गया",
      "meaning_ja": "私たちが出会ったその場所で、時が止まった",
      "type": "poetic_expression",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "आसमां पिघल के, शीशे में ढल के",
      "normalized": "आसमान पिघल के शीशे में ढल के",
      "meaning_ja": "空が溶けて、ガラスのような形になって",
      "type": "metaphor",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "जम गया तो तेरा, चेहरा बन गया",
      "normalized": "जम गया तो तेरा चेहरा बन गया",
      "meaning_ja": "固まると、それはあなたの顔になった",
      "type": "metaphor",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "दुनिया भुला के, तुमसे मिला हूँ",
      "normalized": "दुनिया भुला के तुमसे मिला हूं",
      "meaning_ja": "世界を忘れて、私はあなたに出会った",
      "type": "romantic_expression",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "निकली है दिल से ये दुआ",
      "normalized": "निकली है दिल से ये दुआ",
      "meaning_ja": "この祈りは心から出てきたものだ",
      "type": "poetic_expression",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "तुमसे शुरू तुमपे फ़ना",
      "normalized": "तुमसे शुरू तुमपे फना",
      "meaning_ja": "あなたから始まり、あなたのもとで消えていく",
      "type": "romantic_expression",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "है सुफियाना ये दास्ताँ",
      "normalized": "है सूफियाना ये दास्तां",
      "meaning_ja": "これはスーフィー的な物語である",
      "type": "sufi_like_expression",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "मैं कारवाँ, मंज़िल हो तुम",
      "normalized": "मैं कारवां मंजिल हो तुम",
      "meaning_ja": "私は旅の隊商で、あなたは目的地だ",
      "type": "metaphor",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "दर्द का वो सारा, कोहरा छन गया",
      "normalized": "दर्द का वो सारा कोहरा छन गया",
      "meaning_ja": "痛みの霧がすべて晴れていった",
      "type": "metaphor",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "वीरान था, दिल का जहां",
      "normalized": "वीरान था दिल का जहां",
      "meaning_ja": "心の世界は荒れ果てていた",
      "type": "metaphor",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "इक जिस्म से, इक जान का दर्ज़ा मुझे हासिल हुआ",
      "normalized": "एक जिस्म से एक जान का दर्जा मुझे हासिल हुआ",
      "meaning_ja": "一つの身体から一つの魂のような地位を私は得た",
      "type": "poetic_expression",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "तेरे साथ रिश्ता गहरा बन गया",
      "normalized": "तेरे साथ रिश्ता गहरा बन गया",
      "meaning_ja": "あなたとの関係は深いものになった",
      "type": "romantic_expression",
      "importance": 4,
      "status": "active"
    }
