      "type": "destiny_expression",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "इक हाथ में चिंगारियां",
      "normalized": "एक हाथ में चिंगारियां",
      "meaning_ja": "片手には火花を携えている",
      "type": "poetic_image",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "इक हाथ में साज़ है",
