      "type": "life_expression",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "कर के रहेंगे अदा",
      "normalized": "कर के रहेंगे अदा",
      "meaning_ja": "必ず果たしてみせる、必ず返してみせる",
      "type": "determination_expression",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "आज़ादी है गुनाह तो कुबूल है सज़ा",
