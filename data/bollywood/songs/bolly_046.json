      "importance": 4,
      "status": "active"
    },
    {
      "text": "टूटे सितारों से रोशन हुआ है नूर-ए-खुदा",
      "normalized": "टूटे सितारों से रोशन हुआ है नूर-ए-खुदा",
      "meaning_ja": "砕けた星々によって神の光が照らし出された",
      "type": "spiritual_poetic_image",
      "importance": 4,
      "status": "active"
    },
    {
      "text": "चार दिन की गुलामी",
